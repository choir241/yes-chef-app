{
    "version": 2,
    "builds": [
      {
        "src": "index.ts",
        "use": "@vercel/node",
        "config": { "typescript": true }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/index.ts"
      },
       {
        "src": "/(.*)",
        "dest": "/index.ts"
      }
    ]
  }